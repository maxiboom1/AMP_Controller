function labelUpdate(ledIndex){
   
   if (ledIndex == "led"||ledIndex == "led2"){
         if (params.getValue('led', 0)==params.getValue('led2', 0)){ogscript.setStyle('label.nrcs', params.getValue('led', 0));} else { ogscript.setStyle('label.nrcs', 'bg#BBC037'); }   }
         
   if (ledIndex == 'k21'){ ogscript.setStyle('label.k21', params.getValue('ledK21', 0));  }      
   if (ledIndex == 'k22'){ ogscript.setStyle('label.k22', params.getValue('ledK22', 0));  }            

