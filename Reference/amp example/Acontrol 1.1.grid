      <api name="onload K2">//commands to K2
const listFirstFolderALIAS       = 'CMDS0004A02A' + '\n';
const listNextFoldersALIAS       = 'CMDS0004A02B' + '\n';
const listFirstIdALIAS           = 'CMDS0008A2140000' + '\n';
const listNextIdALIAS            = 'CMDS0006a115FF' + '\n';
const getWorkingBinALIAS         = 'CMDS0004A00F' + '\n';
const getIdCountALIAS            = 'CMDS0004A026' + '\n';
const IDsChangeListReqALIAS      = 'CMDS0004A012' + '\n';
const setDefaultBinALIAS         = 'CMDS0026a20e0009000764656661756c74' + '\n';
const vtr1Connection             = 'CRAT0007204Vtr1\n';  
const vtr2Connection             = 'CRAT0007204Vtr2\n';            
const vtr3Connection             = 'CRAT0007204Vtr3\n';                      
const stopALIAS                  = 'STOP0000\n';
const loopON                     = 'CMDS0006414201' + '\n';
const loopOFF                    = 'CMDS0006414200' + '\n';
const playON                     = 'CMDS00042001' + '\n';
const stop                       = 'CMDS00042000' + '\n';
const eject                      = 'CMDS0004200F' + '\n';
const autoModeON                 = 'CMDS00044041' + '\n';
//returns
const setBinALIAS                = 'a20e';
const eraseIdALIAS               = 'aa10';
const ackALIAS                   = "1001";
const nakALIAS                   = "1111";
const error                      = "1112";
const listFirstFolderReturnALIAS = '822a';
const listNextFolderReturnALIAS  = '822b';
const binListCompleteALIAS       = '802b';
const idReturnALIAS              = '8a14';
const noMoreIdALIAS              = '8014';
const IdInfoReturnALIAS          = '8a13';
const IDsChangelistReturnALIAS   = '8213';

const cueIcon = '&lt;style:fg#000000;i-u:images/cue.svg;&gt;'; 
const playIcon = '&lt;style:fg#27D10D;i-u:images/play.svg;&gt;'; 
const redBackground = 'N/A       &lt;bg#A92121&gt;';

const emptyArr = [];                                 // blank string for reset clips object
const plzConnect = ['please connect'];
ogscript.putObject('idStatusCounter1',empty);    // reset idstatus object  
ogscript.putObject('idStatusCounter2',empty);    // reset idstatus object  

ogscript.putObject('busy1', 0);                  // reset busy flag  
ogscript.putObject('busy2', 0);                  // reset busy flag  

params.setValue('ledK21', 0, '&lt;#red&gt;');
params.setValue('ledK22', 0, '&lt;#red&gt;');

ogscript.putObject('K21vtr1',null);     
ogscript.putObject('K22vtr1',null);     

ogscript.putObject('binList22',emptyArr);               
ogscript.putObject('binList21',emptyArr);
ogscript.putObject('clips22',emptyArr);               
ogscript.putObject('clips21',emptyArr);
params.setAllValues('clipTable', [{'clipname':'', 'available':''}]);

var x = params.createIntChoiceConstraint(plzConnect);
params.replaceConstraint("binList", x);
params.setValue('binList', 0, 0);</api>
      <api name="K2 both msg router">function messageRouterK21(msg){
   //ogscript.debug('recieved msg from k21: ' + msg );
   
   if (msg.slice(0,4) == listFirstFolderReturnALIAS){ list1Folder21(msg.slice(8));  }                                        // first folder return (822a) 
   if (msg.slice(0,4) == listNextFolderReturnALIAS) { listNextBin21(msg.slice(8));  }                                        // next folder return (822b)
   if (msg == binListCompleteALIAS)                 { binListFinilize21();         }                                         // folder list comlete (802b)
   if (msg.slice(0,4) == idReturnALIAS  )           { nextId21(msg.slice(8));ogscript.putObject('ack21','');  }              // ID list (or single if it is the first id) return (8a14) 
   if (msg == noMoreIdALIAS)                        { ogscript.putObject('ack21',''); clipListFinilize();autoModeOn21();   }                // No more id found (8014) 
   if (msg.slice(0,4) == IdInfoReturnALIAS)         {dateConvertor21(msg.slice(8,24),msg.slice(40,48),msg.slice(60,68));}    // Id info return (8a13)
   if (msg == ackALIAS &amp;&amp; ogscript.getObject('ack21') == 'setBin' ){ogscript.asyncExec(firstIdRequest21,500);ogscript.putObject('ack21','');} // if recieved ack (1001) and ack flag was from setDefaulBin
   if (msg.slice(0,4) == IDsChangelistReturnALIAS&amp;&amp;msg.length!==8)  { IDsChangeEvent21(msg.slice(8));         }       // IDs Changed List (8213), msg.length!==8 will filter msg with no changes
 }

function messageRouterK22(msg){
      
   if (msg.slice(0,4) == listFirstFolderReturnALIAS){ list1Folder22(msg.slice(8));  }                                         // first folder return (822a) 
   if (msg.slice(0,4) == listNextFolderReturnALIAS) { listNextBin22(msg.slice(8));  }                                         // next folder return (822b)
   if (msg == binListCompleteALIAS)                 { binListFinilize22();         }                                          // folder list comlete (802b)
   if (msg.slice(0,4) == idReturnALIAS  )           { nextId22(msg.slice(8));ogscript.putObject('ack22','');  }               // ID list (or single if it is the first id) return (8a14) 
   if (msg == noMoreIdALIAS)                        { ogscript.putObject('ack22',''); clipListFinilize(); autoModeOn22();  }                 // No more id found (8014) 
   if (msg.slice(0,4) == IdInfoReturnALIAS)         {dateConvertor22(msg.slice(8,24),msg.slice(40,48),msg.slice(60,68));}     // Id info return (8a13)
   if (msg == ackALIAS &amp;&amp; ogscript.getObject('ack22') == 'setBin' ){ogscript.asyncExec(firstIdRequest22,500);ogscript.putObject('ack22','');} // if recieved ack (1001) and ack flag was from setDefaulBin
   if (msg.slice(0,4) == IDsChangelistReturnALIAS&amp;&amp;msg.length!==8)  { IDsChangeEvent22(msg.slice(8));         }      // IDs Changed List (8213), msg.length!==8 will filter msg with no changes
 }

// AMP messages decoder to ascii names + server (TLV1/TLV2) objects array
function dataConvertor(msg,totalLength,server){                                                      

   var listAndServer = [];
   var list = [];            
   var itemName,i,result,x; 
    
   while(totalLength&gt;0){
      result = '';
      countAndNameNumber =  4 + parseInt(msg.slice(0,4),16) * 2;  // number of CLIPNAME-LEN + CLIP NAME
      itemName = msg.slice( 4 , countAndNameNumber);
      msg = msg.slice(countAndNameNumber); 
      itemName = itemName.match(/.{1,2}/g);      // create array of hex strings
      
      for (i=0; i&lt;itemName.length; i++) {
         x = parseInt(itemName[i], 16);            // convert hex to dec numbers
         result += String.fromCharCode(x).toUpperCase();  // This will translate hex code to ascii+ to uppercase  
      }
   
      listAndServer.push({name:result, server:server})  //***
      list.push(result);
      totalLength -= countAndNameNumber;
      }
    
   return {list:list,listAndServer:listAndServer}
            
      }

function ampMessageBuilder(string,cmdType){   //CMDS0026 a20e 0009 0007 64656661756c74

   var clipNameLen = ('0000' + (string.length).toString(16)).slice(-4); 
   var actualCountByte = ('0000' + (string.length+2).toString(16)).slice(-4);
   var totalCmdCounter = ('0000'+(string.length*2+12).toString(10)).slice(-4); 
   var hex = string.charCodeAt(0).toString(16);
   
   for (i = 1; i &lt; string.length; i++) {
        hex += string.charCodeAt(i).toString(16);
      } 
   
   return 'CMDS' + totalCmdCounter + cmdType + actualCountByte + clipNameLen + hex + '\n' ;
  
   }   

function onlyUnique(value, index, self) {
   return self.indexOf(value) === index;
}
// Clips names convertor to send to K2
function hexToAscii(msg){                                                      
      //ogscript.debug('convertor recieved: ' + msg);
      var result = '';
      var x;
      var array = msg.match(/.{1,2}/g);            // create array of hex strings      
      for (ii=0; ii&lt;array.length; ii++) {
         x = parseInt(array[ii], 16);               // convert hex to dec numbers
         result += String.fromCharCode(x);   
      }
   //ogscript.debug('convertor return: ' + result);     
   return result;          
      }</api>
      <api name="K2 API">function firstFolderRequest21(){
