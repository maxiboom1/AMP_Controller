      <api name="Router,Parser,ACK">function mosRouter(message){   
   
   log(message); // this will send the raw protocol message to log 
   var xml    = XMLparser(ogscript.parseXML(message)); 
   if(xml.roCreate==true)       {roCreateEvent1(xml,'roCreate'); }                        
   if(xml.roListAll==true )     {setLineupList(xml); }                  
   if(xml.roStorySend==true)    {roStorySendEvent1(xml); }   
   if(xml.roStoryMove==true)    {roStoryMoveEvent(xml); }            
   if(xml.roDelete==true)       {deleteRO(xml); }         
   if(xml.roList==true)         {roCreateEvent1(xml,'roList'); }   
   if(xml.roStoryDelete==true)  {storyDeleteEvent(xml); }    
   if(xml.roStoryInsert==true)  {roStoryInsertEvent(xml); }   
   if(xml.roStoryReplace==true) {roStoryReplaceEvent(xml); } 
   if(xml.roStoryAppend==true)  {roStoryAppendEvent(xml); } 
   if(xml.meta==true)           {roMetadataReplace(xml);  }          
   }


//******************************* ACK functions ***********************************
function ack(xml){ 
    
    var messageID  = ogscript.getObject('ackCount');  
    var NRCS = ogscript.getObject('E');
    var ack = ackGen(messageID,Number(xml.roID));
    NRCS.writeAsBytes(ack);     
    log(mosAck0 + messageID + mosAck1 + Number(xml.roID) + mosAck2 ); // this will send ack to log
    ogscript.putObject('ackCount', messageID+1);       
   }


function ackGen(messageID,roID){
   return strToHex(mosAck0) + numberToHex(messageID) + strToHex(mosAck1) + numberToHex(Number(roID)) + strToHex(mosAck2);
   }

//******************************* data convertors functions ************************

function numberToHex(number){   
   //ogscript.debug('numberToHex');
   var hex = '';
   number=number.toString().split(''); 
   for(i=0;i&lt;number.length;i++){
      hex +='00'+ (48+ Number(number[i])).toString(16);    
      }  
   return hex;    
   }   

function strToHex(str){   
   var hex = '';
   str=str.split(''); 
   for(i=0;i&lt;str.length;i++){
      hex +='00'+ Number(str[i].charCodeAt(0)).toString(16);    
      }  
   return hex;    
   }

function rowBuilder(tableIndex,storyIndex,roID,storyID){
   //ogscript.debug('rowBuilder');   
   //var red1 = '&lt;html&gt;&lt;font color="#FF0000"&gt;';
   //var red2 = '&lt;/font&gt;&lt;/html&gt;';
   var video= params.getValue('ROTable'+tableIndex +'.' + storyIndex  + '.video', 0); 
   var storySlug = params.getValue('ROTable'+tableIndex +'.' + storyIndex +  '.storySlug', 0);
   var storyNum =  params.getValue('ROTable'+tableIndex +'.' + storyIndex + '.storyNum', 0);
   var channel =   params.getValue('ROTable'+tableIndex +'.' + storyIndex + '.channel', 0);
   var available = params.getValue('ROTable'+tableIndex +'.' + storyIndex + '.available', 0); 
   var loop =      params.getValue('ROTable'+tableIndex +'.' + storyIndex + '.loop', 0); 
   var source =    params.getValue('ROTable'+tableIndex +'.' + storyIndex + '.source', 0);
   var cue =       params.getValue('ROTable'+tableIndex +'.' + storyIndex + '.cue', 0);  
   if(video==null){video='';}
   if(storySlug==null){storySlug='';}
   if(storyNum==null){storyNum='';}
   if(channel==null){channel='';}
   if(available==null){available='';}
   if(storyID==null){storyID='';}
   if(roID==null){roID='';}
   if(loop==null){loop='';}
   if(source==null){loop='';}
   if(cue==null){cue='';}
   var newValue = {"channel": channel,"available": available ,"video": video,"storySlug": storySlug ,"storyNum": storyNum,"storyID": storyID,"roID":roID,"loop":loop,"source":source,"cue":cue};
   
   return newValue;
   
   }      


// ***************************** XML PARSER *************************************


function XMLparser(xml){
 
   var roIDNode =       xml.getElementsByTagName('roID'); 
   var roSlugNode =     xml.getElementsByTagName('roSlug');
   var storyIDNode =    xml.getElementsByTagName('storyID');
   var storySlugNode =  xml.getElementsByTagName('storySlug');
   var storyNumNode =   xml.getElementsByTagName('storyNum');
   var storyNode =      ogscript.runXPath('//story', xml);

   var roID =           roIDNode.item(0);                                   if(roID!==null){roID = roID.getTextContent();}else{roID='';}
   var roSlug =         roSlugNode.item(0);                                 if(roSlug!==null){roSlug = roSlug.getTextContent();}else{roSlug='';}
   var storyID0 =       storyIDNode.item(0);                                if(storyID0!==null){storyID0 = storyID0.getTextContent();}else{storyID0='';} 
   var storyID1 =       storyIDNode.item(1);                                if(storyID1!==null){storyID1 = storyID1.getTextContent();}else{storyID1='';} 
   var storySlug =      storySlugNode.item(0);                              if(storySlug!==null){storySlug = storySlug.getTextContent();}else{storySlug='';}
   var storyNum  =      storyNumNode.item(0);                               if(storyNum!==null){storyNum = storyNum.getTextContent();}else{storyNum='';}
   var source  =        xml.getElementsByTagName('SOURCE').item(0);         if(source!==null){source = source.getTextContent();}else{source='';}
   
   var roList =         xml.getElementsByTagName('roList').item(0);         if(roList!==null){roList = true}
   var roListAll =      xml.getElementsByTagName('roListAll').item(0);      if(roListAll!==null){roListAll = true}
   var roCreate =       xml.getElementsByTagName('roCreate').item(0);       if(roCreate!==null){roCreate = true}
   var roDelete =       xml.getElementsByTagName('roDelete').item(0);       if(roDelete!==null){roDelete = true}
   var roStorySend =    xml.getElementsByTagName('roStorySend').item(0);    if(roStorySend!==null){roStorySend = true}
   var roStoryMove =    xml.getElementsByTagName('roStoryMove').item(0);    if(roStoryMove!==null){roStoryMove = true}
   var roStoryDelete =  xml.getElementsByTagName('roStoryDelete').item(0);  if(roStoryDelete!==null){roStoryDelete = true}
   var roStoryInsert =  xml.getElementsByTagName('roStoryInsert').item(0);  if(roStoryInsert!==null){roStoryInsert = true}
   var roStoryReplace = xml.getElementsByTagName('roStoryReplace').item(0); if(roStoryReplace!==null){roStoryReplace = true}
   var roStoryAppend =  xml.getElementsByTagName('roStoryAppend').item(0);  if(roStoryAppend!==null){roStoryAppend = true}
   var meta =  xml.getElementsByTagName('roMetadataReplace').item(0);       if(meta!==null){meta = true}
   var video = xml.getElementsByTagName('video').item(0);                   if(video!==null){video = video.getTextContent();}else{video='';}
   
   return {
      
      roID: roID,
      roSlug:roSlug,
      roIDNode:roIDNode,
      roSlugNode:roSlugNode,
      storyIDNode:storyIDNode,
      storySlugNode:storySlugNode,
      storyNumNode:storyNumNode,
      storyNode:storyNode,
      storyID0: storyID0,
      storyID1:storyID1,
      storySlug:storySlug,
      storyNum:storyNum,
        
      roList:roList,
      roListAll:roListAll,
      roCreate:roCreate,
      roDelete:roDelete,
      roStorySend:roStorySend,
      roStoryMove:roStoryMove,
      roStoryDelete:roStoryDelete,
      roStoryInsert:roStoryInsert,
      roStoryReplace:roStoryReplace,
      roStoryAppend:roStoryAppend,
      video:video.toUpperCase(),
      source:source,
      meta:meta
      
        
    };
   
   }

function log(cmd){
   var output;
   var clock = params.getValue('realClock', 0) + "\n";
   var date = params.getValue('dateForLog', 0);
   var fileContent = ogscript.post("logs\\" + date + ".txt", null);  //READ THE CURRENT FILE, IF EXISTS
   
      if (fileContent != null)
      {
         fileContent += clock +cmd;
         ogscript.saveToFile("logs\\" + date + ".txt",fileContent + "\n"); // SAVE TO THE FILE
         
         }else{
         
        output = ogscript.createFileOutput("logs\\" + date + ".txt",false); 
        ogscript.saveToFile("logs\\" + date + ".txt",clock+cmd + "\n"); // SAVE TO THE FILE 
        output.close(); 
      }

   }</api>
      <api name="functions">function sendRoReqAll(){  //triggered from client listener onConnect() event
   //ogscript.debug('sendRoReqAll');   
   var client = ogscript.getObject('client10541');
   client.writeAsBytes(strToHex(roReqAll));
   
}


function sendRoReq(){  //triggered first by setLineupList() (who generate lineup list object 'rolist', and then by roCreateEvent())
   //ogscript.debug('sendRoReq');   
   var count = Number(ogscript.getObject('ROCounter'));        
   var ROList = ogscript.getObject('roList');
   if (count&gt;0){
      var NRCSclient = ogscript.getObject('client10541');
      NRCSclient.writeAsBytes(strToHex('&lt;mos&gt;&lt;mosID&gt;VTR1&lt;/mosID&gt;&lt;ncsID&gt;INCEPTION&lt;/ncsID&gt;&lt;messageID&gt;&lt;/messageID&gt;&lt;roReq&gt;&lt;roID&gt;') + numberToHex(Number(ROList[count-1])) + strToHex('&lt;/roID&gt;&lt;/roReq&gt;&lt;/mos&gt;')); 
      ogscript.putObject('ROCounter', count-1);        
      } 
}


function setLineupList(xml) {  //triggered by &lt;roListAll&gt;   
   //ogscript.debug('setLineupList');   
   var ROList = [];
   for (i=0 ; i&lt;(xml.roIDNode).length ;i++){
            
      var roID    =  xml.roIDNode.item(i).getTextContent();   
      var roSlug  =  xml.roSlugNode.item(i).getTextContent(); 
      ROList.push(roID);
      //Set Names to empty buttons , and set roID to empty table
      for (x = 1; x &lt; 7; x++) {  
         if(params.getValue("ROTable" + x +".0" + ".roID", 0) == "" ){   
            
            params.setValue("ROTable" + x +".0" + ".roID",0,roID);
            ogscript.rename('table'+x, roSlug); 
            break;            
         }      
      }                    
   }
   var ROListObject = ogscript.putObject('roList',ROList); 
   ogscript.putObject('ROCounter', ROList.length);        
   if(ROList.length&gt;0){sendRoReq(ROListObject);} // in case there is no monitored lineups, won't send roReq
}


function roMetadataReplace(xml){
   var x;
   for (x = 1; x &lt; 7; x++) {  
         if(params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID ){ogscript.rename('table'+x, xml.roSlug); break;}            
         }      
   ack(xml);
   }


function roStorySendEvent1(xml){  //triggered by &lt;roStorySend&gt;
   //ogscript.debug('roStorySendEvent1');   
   //this check if the current storyID match lineupLoad - if it is - then the lineup loading finished, and we can fire full listmatch
   if(xml.storyID0 == ogscript.getObject('lineupLoad')){ogscript.putObject('lineupLoad','');ogscript.asyncExec(matchLists,300);ogscript.rename('bar','LINEUP LOADED');  }
   
   for (x = 1; x &lt; 7; x++) {  
      if(params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID ){var tableIndex = (x).toString();}
      } 
  
   if(tableIndex!==undefined){   
      var structCount = params.getElementCount('ROTable' + tableIndex);
      var currentVideo,currentSource;
      for(i=0;i&lt;structCount;i++){
         if (params.getValue('ROTable'+tableIndex +'.' + i + '.storyID', 0) == xml.storyID0){
             currentVideo = params.getValue('ROTable'+tableIndex +'.' + i + '.video', 0);
             currentSource = params.getValue('ROTable'+tableIndex +'.' + i + '.source', 0);
             // The idea is to skip all un-changed updates  - if video slug doesnt changed - do nothing. 
             if(xml.video!==currentVideo){
               params.setValue("ROTable" + tableIndex + "." + i + ".video",0, xml.video);if(xml.video == ''){params.setValue("ROTable" + tableIndex + "." + i + ".available",0, '');} 
               if(ogscript.getObject('lineupLoad')==''){ogscript.asyncExec(matchLists,100);}
                  }
             if(xml.source!==currentSource){params.setValue("ROTable" + tableIndex + "." + i + ".source",0, xml.source); }
             break;                              
            }      
         }
      }
   ack(xml); 
      }


function createNewTableRow(storySlug,storyNum,storyID,tableIndex,roID){  //triggered by roCreateEvent1() func
   //ogscript.debug('createNewTableRow');      
   var structCount = params.getElementCount('ROTable'+tableIndex);
   if (structCount == 1 &amp;&amp; params.getValue('ROTable' + tableIndex + '.0.storySlug', 0) == "") {structCount = 0;}
   var newValue = {"channel": "","available": "" ,"video": "","storySlug": storySlug ,"storyNum": storyNum,"storyID": storyID,"roID":roID,"loop":"","source":"","cue":"" };
   params.setValue('ROTable' + tableIndex, structCount, newValue);
}


function roCreateEvent1(xml,eventType){  //triggered by &lt;roList&gt; and &lt;roCreate&gt;
   //ogscript.debug('roCreateEvent1');   
   var storyID,storySlug,storyNum; 
   var tableIndex = '';
   for (x = 1; x &lt; 7; x++) {            // match roID to Table roID , in &lt;roList&gt; case while table ID was set by setLineupList()
      if(params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID ){tableIndex = (x).toString();  }  
      }        

   if(tableIndex==''){               // If &lt;roCreate&gt; recieved (no such tableIndex it tables) - find empty table,   
    for (x = 1; x &lt; 7; x++) {  
       if(params.getValue("ROTable" + x +".0" + ".roID", 0) == ''){
          tableIndex = (x).toString(); 
          params.setValue("ROTable" + x +".0" + ".roID",0,xml.roID);
          ogscript.rename('table'+tableIndex,xml.roSlug)
          break;  
       }   
     }    
   } 
   params.setAllValues('ROTable'+tableIndex, empty); //reset table 
   roStory = xml.storyNode;       
   for(i=0;i&lt;roStory.length;i++){
     
      storyID    = roStory.item(i).getElementsByTagName("storyID").item(0);
      storySlug  = roStory.item(i).getElementsByTagName("storySlug").item(0);
      storyNum = roStory.item(i).getElementsByTagName("storyNum").item(0);
      
      if(storyID!==null)    {storyID=storyID.getTextContent();}     else   { storyID=''; }    // Those condition makes sure 
      if(storySlug!==null)  {storySlug=storySlug.getTextContent();} else   { storySlug=''; }  // that if there is no such values in slug, 
      if(storyNum!==null)   {storyNum=storyNum.getTextContent();}   else   { storyNum=''; }   // it will fill the cells with blank 
      
      createNewTableRow(storySlug,storyNum,storyID,tableIndex,xml.roID);
     
      } 
   //This will set lineupLoad object to last storyId - so we know that if lineupLoad!== '', the lineup is loading.
   ogscript.putObject('lineupLoad',params.getValue("ROTable" + tableIndex +"." + (i-1) + ".storyID", 0)); 
   if(eventType!=='roCreate'){ogscript.asyncExec(sendRoReq,1000);}else{ack(xml);}
   
      }   


function deleteRO(xml){ //triggered by &lt;roDelete&gt;
   //ogscript.debug('deleteRO');     
   for (x = 1; x &lt; 7; x++) { if(params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID ){var tableIndex = (x).toString();  }   } 
   params.setAllValues('ROTable'+tableIndex, empty); 
   ogscript.rename('table'+tableIndex,''); 
   ack(xml);
   }




//-------------------------------------------------------- S L U G   R E O R D E R triggered by &lt;storyMoveEvent&gt; -  -------------------------------------------------

function roStoryMoveEvent(xml){
   var structCount,storyID,srcIndex,dstIndex,srcNewValue,dstNewValue,tableIndex;
   //ogscript.debug('roStoryMoveEvent');   
   //find the table with reported roID
   for (x = 1; x &lt; 7; x++) {   if(params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID ){tableIndex = (x).toString();  }   } 
   
   if(tableIndex!==undefined&amp;&amp;params.getElementCount('ROTable'+tableIndex)&gt;1){           // if we found table with same roID as in the message, else just send ack.       
      
      structCount = params.getElementCount('ROTable'+tableIndex);  
      // Create srcNewValue and dstNewValue objects with copy of all src and dst cells data
      for(i=0;i&lt;structCount;i++){ 
         storyID = params.getValue('ROTable'+tableIndex +'.' + i + '.storyID', 0);
         
         if(storyID==xml.storyID0){ srcIndex =i;   
           srcNewValue = rowBuilder(tableIndex,srcIndex,xml.roID,storyID); //this is object with -=channel,available,video,storySlug,storyNum,storyID,roID,loop,source=- properties
           }
                 
         if(storyID==xml.storyID1){  dstIndex =i; 
           dstNewValue = rowBuilder(tableIndex,dstIndex,xml.roID,storyID); //this is object with -=channel,available,video,storySlug,storyNum,storyID,roID,loop,source=- properties
           }  
           }
       
      swapItems(srcIndex,srcNewValue,dstIndex,dstNewValue,tableIndex,xml.roID,structCount,xml);
       
      } else { ack(xml); }   
   }

//params.setValue("ROTable" + x +".0" + ".roID",0,roID);
function setValue(tableIndex,index,rowObject){
   params.setValue("ROTable" + tableIndex +"." + index + ".channel",0,rowObject.channel); 
   params.setValue("ROTable" + tableIndex +"." + index + ".available",0,rowObject.available);
   params.setValue("ROTable" + tableIndex +"." + index + ".video",0,rowObject.video); 
   params.setValue("ROTable" + tableIndex +"." + index + ".storySlug",0,rowObject.storySlug);
   params.setValue("ROTable" + tableIndex +"." + index + ".storyNum",0,rowObject.storyNum);
   params.setValue("ROTable" + tableIndex +"." + index + ".storyID",0,rowObject.storyID);
   params.setValue("ROTable" + tableIndex +"." + index + ".roID",0,rowObject.roID); 
   params.setValue("ROTable" + tableIndex +"." + index + ".loop",0,rowObject.loop);
   params.setValue("ROTable" + tableIndex +"." + index + ".source",0,rowObject.source); 
   params.setValue("ROTable" + tableIndex +"." + index + ".cue",0,rowObject.cue); 
   }


function swapItems(srcIndex,srcNewValue,dstIndex,dstNewValue,tableIndex,roID,structCount,xml){
   //ogscript.debug('swapItems'); 
   var selectionStoryID = params.getValue('ROTable'+tableIndex +'.' + params.getValue('selected'+tableIndex, 0) + '.storyID', 0);           
   if (srcIndex&lt;dstIndex){

   for(i=srcIndex; i &lt; dstIndex; i++){
     var storyID = params.getValue('ROTable'+tableIndex +'.' + (i+1) + '.storyID', 0); 
     var newValue = rowBuilder(tableIndex,(i+1),roID,storyID);
     //params.setValue('ROTable' + tableIndex, i, newValue);
     setValue(tableIndex,i,newValue);//new
   } 
   //params.setValue('ROTable' + tableIndex, dstIndex-1, srcNewValue);
   setValue(tableIndex,dstIndex-1,srcNewValue); //new
   selection(structCount, selectionStoryID,tableIndex);
      }

   if (srcIndex&gt;dstIndex){

   for(i=srcIndex; i &gt; dstIndex; i--){    // src:3 , dst: 1
     var storyID = params.getValue('ROTable'+tableIndex +'.' + (i-1) + '.storyID', 0);
     var newValue = rowBuilder(tableIndex,(i-1),roID,storyID);
     //params.setValue('ROTable' + tableIndex, i, newValue);
     setValue(tableIndex,i,newValue);//new
   } 
   //params.setValue('ROTable' + tableIndex, dstIndex, srcNewValue);
   setValue(tableIndex,dstIndex,srcNewValue);//new
   selection(structCount, selectionStoryID,tableIndex); 
   
      }

   if (dstIndex==undefined){

   for(i=srcIndex; i &lt; structCount-1; i++){
     var storyID = params.getValue('ROTable'+tableIndex +'.' + (i+1) + '.storyID', 0);
     var newValue = rowBuilder(tableIndex,(i+1),roID,storyID);
     //params.setValue('ROTable' + tableIndex, i, newValue);
     setValue(tableIndex,i,newValue);//new
     
   } 
   //params.setValue('ROTable' + tableIndex, structCount-1, srcNewValue);
   setValue(tableIndex,structCount-1,srcNewValue);//new
   selection(structCount, selectionStoryID,tableIndex); 
      }
   
   ack(xml);  
   }


function roStoryAppendEvent(xml){
   //ogscript.debug('roStoryAppendEvent');   
   for (x = 1; x &lt; 7; x++) { if (params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID )  {var tableIndex = (x).toString();  }  }  
   var structCount = params.getElementCount('ROTable'+tableIndex); 
   var selectionStoryID = params.getValue('ROTable'+tableIndex +'.' + params.getValue('selected'+tableIndex, 0) + '.storyID', 0);              
   if(tableIndex!==undefined&amp;&amp;structCount&gt;1){       //If we found table with roID, else just ack          
      var newObject = {"channel": "","available": "" ,"video": "","storySlug": xml.storySlug ,"storyNum": xml.storyNum,"storyID": xml.storyID0,"roID":xml.roID,"loop":"","source":"","cue":"" };
      params.setValue('ROTable' + tableIndex, structCount, newObject); 
      selection(structCount, selectionStoryID,tableIndex);
      }       
   ack(xml);     
}


function roStoryReplaceEvent(xml){
   //ogscript.debug('roStoryReplaceEvent');   
   for (x = 1; x &lt; 7; x++) { if (params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID )  {var tableIndex = (x).toString();  }  }  
   var structCount = params.getElementCount('ROTable'+tableIndex);     
   if(tableIndex!==undefined&amp;&amp;structCount&gt;1){ //If we found table with roID, else just ack    
      var storyID;
      for(i=0;i&lt;structCount;i++){   //find position index of replaced story
         storyID = params.getValue('ROTable'+tableIndex +'.' + i + '.storyID', 0);      
         if(storyID==xml.storyID0){
            params.setValue("ROTable" + tableIndex + "." + i + ".storyID",0, xml.storyID1);    // Set new values      
            params.setValue("ROTable" + tableIndex + "." + i + ".storySlug",0, xml.storySlug); // for replaced       
            params.setValue("ROTable" + tableIndex + "." + i + ".storyNum",0, xml.storyNum);   // story    
              }        
           }
        }
   ogscript.debug('roStoryReplaceEvent done');     
   ack(xml);     
     }


function roStoryInsertEvent(xml){
   //ogscript.debug('roStoryInsertEvent');   
   var tableIndex,index,newValue; 

   for (x = 1; x &lt; 7; x++) { if (params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID )  {tableIndex = (x).toString();  }  } 
   var selectionStoryID = params.getValue('ROTable'+tableIndex +'.' + params.getValue('selected'+tableIndex, 0) + '.storyID', 0);         
   var structCount = params.getElementCount('ROTable'+tableIndex);      
   if(tableIndex!==undefined&amp;&amp;structCount&gt;1){ //If we found table with roID, else just ack    
      ogscript.debug('structCount: ' + structCount);
      for(i=0;i&lt;structCount;i++){   //find insert position index
         storyID = params.getValue('ROTable'+tableIndex +'.' + i + '.storyID', 0);      
         if(storyID==xml.storyID0){index =i;break; }        
       }

      for(i=structCount-1; i&gt;index-1 ;i--){ 
         storyID = params.getValue('ROTable'+tableIndex +'.' + i + '.storyID', 0);
         newValue = rowBuilder(tableIndex,i,xml.roID,storyID);
         params.setValue('ROTable' + tableIndex, i+1, newValue);               
         }
      
      var xx = {"channel": "","available": "" ,"video": "","storySlug": xml.storySlug ,"storyNum": xml.storyNum,"storyID": xml.storyID1,"roID":xml.roID,"loop":"","source":"","cue":"" };
  
      params.setValue('ROTable' + tableIndex, index, xx); 
      selection(structCount, selectionStoryID,tableIndex);
      }       
   ack(xml);
   
}

   
function storyDeleteEvent (xml){
  
   //ogscript.debug('storyDeleteEvent');        
   for (x = 1; x &lt; 7; x++) { if (params.getValue("ROTable" + x +".0" + ".roID", 0) == xml.roID )  {var tableIndex = x;  }  } 
    
   var structCount = params.getElementCount('ROTable'+tableIndex);     
   var selectionStoryID = params.getValue('ROTable'+tableIndex +'.' + params.getValue('selected'+tableIndex, 0) + '.storyID', 0);         
   if(tableIndex!==undefined&amp;&amp;structCount&gt;1){ //If we found table with roID, else just ack      
      // find deletedID row in table
      for(i=0;i&lt;structCount;i++){         
         
         if(params.getValue("ROTable" + tableIndex +"." + i + ".storyID", 0) == xml.storyID0){
            params.setValue('selected1', 0, i);
            params.getParam('ROTable'+tableIndex, i).remove();
            break;            
         
         }
      } 
      selection(structCount, selectionStoryID,tableIndex);  
   }  
   ack(xml);
}


function selection(structCount, selectionStoryID,tableIndex){
   for(i=0;i&lt;structCount+1;i++){
   if(selectionStoryID == params.getValue('ROTable'+tableIndex +'.' + i + '.storyID', 0) ){ 
      params.setValue('selected'+ tableIndex, 0, i); 
      break;
      }
   }     
}</api>
      <api name="glossary">function resetRoID(){
   //ogscript.debug('resetRoID');
   for (i = 1; i &lt; 7; i++) {
      params.setValue("ROTable" + i +".0" + ".roID",0,"");
      ogscript.rename('table'+i, '');
     }  
     } 

function resetTables(){
   //ogscript.debug('resetTables');
   for (i = 1; i &lt; 7; i++){
   params.setAllValues('ROTable'+i, empty);
   }
}

function dynamicTable(tableIndex){
   //ogscript.debug('dynamicTable');
   ogscript.putObject('activeTable',tableIndex);
   //style="bdr#modaloverlay;bdr:thick;bg#textbg;"
   var textSize = 18;
   //var start = '&lt;param evenstyle="txt-align:east;size:' + textSize + '" expand="true" style="bg#textbg;" height="860" id="" left="0" oddstyle="txt-align:east;size:' + textSize + '" oid="ROTable'  + tableIndex; 
   var start = '&lt;param evenstyle="txt-align:east;size:' + textSize + '" expand="true" style="bg#textbg;brd:none" height="880" id="" left="1" oddstyle="txt-align:east;size:' + textSize + '" oid="ROTable'  + tableIndex; 
   var start2 = '" showlabel="false" top="0" width="1200"&gt;size:Big';     
   var config1 = '&lt;config key="w.selectionparam"&gt;selected' + tableIndex + '&lt;/config&gt;';  
   var config2 = '&lt;config key="w.cellediting"&gt;false&lt;/config&gt;&lt;config key="w.columns"&gt;channel,cue,available,loop,video,source,storySlug,storyNum&lt;/config&gt;';   
   var config3 = '&lt;config key="w.padding"&gt;0,17&lt;/config&gt;&lt;config key="w.showheader"&gt;false&lt;/config&gt;';
   var config4 = '&lt;config key="w.colminwidth.0"&gt;40&lt;/config&gt;&lt;config key="w.colminwidth.1"&gt;60&lt;/config&gt;&lt;config key="w.colminwidth.2"&gt;130&lt;/config&gt;&lt;config key="w.colminwidth.3"&gt;80&lt;/config&gt;&lt;config key="w.colminwidth.4"&gt;400&lt;/config&gt;';
   
   var config44= '&lt;config key="w.colminwidth.5"&gt;90&lt;/config&gt;&lt;config key="w.colminwidth.6"&gt;320&lt;/config&gt;&lt;config key="w.colminwidth.7"&gt;80&lt;/config&gt;';
   
   var config5 = '&lt;config key="w.rowheight"&gt;30&lt;/config&gt;&lt;config key="w.hgrid"&gt;true&lt;/config&gt;&lt;config key="w.columnlock"&gt;true&lt;/config&gt;'; ///&lt;config key="w.showheader"&gt;true&lt;/config&gt;
   var config6 = '&lt;config key="w.vgrid"&gt;false&lt;/config&gt;&lt;config key="w.scrollselection"&gt;false&lt;/config&gt;&lt;/param&gt;';
   return start+start2 + config1 + config2 +config3 + config4 + config44 + config5+ config6;
   
   }

