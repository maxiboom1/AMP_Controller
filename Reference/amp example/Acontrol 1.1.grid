function nextId21(msg){
   var clips = ogscript.getObject('clips21');                                                 // get array object with first bin name from list1Folder func.
   clips = clips.concat(dataConvertor(msg,msg.length,params.getValue('K2Primary', 0)).listAndServer);       // add list returned from dataConvertor() to binList 
   ogscript.putObject('clips21',clips);        
   nextIdRequest21();
   }
function nextId22(msg){
   var clips = ogscript.getObject('clips22');                   // get array object with first bin name from list1Folder func.
   clips = clips.concat(dataConvertor(msg,msg.length,params.getValue('K2Secondary', 0)).listAndServer);       // add list returned from dataConvertor() to binList 
   ogscript.putObject('clips22',clips); 
   nextIdRequest22();
   }


// This is main function that recieve and merge cliplists from 2 K2 servers
function clipListFinilize(){
   
   var clips21 = ogscript.getObject('clips21');                                                            // get object with all cliplist from server 21.
   var clips22 = ogscript.getObject('clips22');                                                            // get object with all cliplist from server 22.
   var skip = 0;  var list = []; 
  // params.setAllValues('clipTable', [{'clipname':'', 'available':''}]);
   
   //Loop for each clips21 array and match it with each clips22 element
   for(i=0; clips21.length&gt;i; i++){        
      skip = 0;   
      for(ii=0; clips22.length&gt;ii; ii++){                                                                            
         if(clips21[i].name == clips22[ii].name){                                                                    
           list.push({clipname:clips21[i].name,'available': clips21[i].server + "," + clips22[ii].server}); // clip exists on both servers
           skip = 1;
           break;
            }   
         }          
      if(skip == 0){ list.push({clipname:clips21[i].name,'available': clips21[i].server}); }                // clip exist only on server 21        
      }
   
   // now we need to find out only uniq clips22 items
   for(i=0; clips22.length&gt;i; i++){      
      skip = 0;
      for(ii=0; clips21.length&gt;ii; ii++){                                                                             
         if(clips22[i].name == clips21[ii].name){                                                                    
           skip = 1;
            }   
         }      
      if(skip == 0){ list.push({clipname:clips22[i].name,'available': clips22[i].server}); }                // clip exist only on server 22 
      }
   // This will sort the final items 
   list.sort(function(a, b){
   var x = a.clipname.toLowerCase();
   var y = b.clipname.toLowerCase();
   if (x &lt; y) {return -1;}
   if (x &gt; y) {return 1;}
   return 0;
   });
  
   params.setAllValues("clipTable", list);      
   ogscript.putObject('busy21',0);          // reset busy object 
   ogscript.putObject('busy22',0);          // reset busy object        
   //matchLists();
   }



function IDsChangeEvent21(msg){
   
   var volumeNamelength = parseInt(msg.slice(0,4),16);           msg = msg.slice(4);
   var volumeName=msg.slice(0,volumeNamelength * 2);             msg = msg.slice(volumeNamelength * 2);  
   var folderNameLen = parseInt(msg.slice(0,4),16);              msg = msg.slice(4);
   var folderName = hexToAscii(msg.slice(0,folderNameLen*2));    msg = msg.slice(folderNameLen * 2);  
   var clipChangedCounter = parseInt(msg.slice(0,2),16);         msg = msg.slice(2);
   var eventType,clipLen,clipName;
      
   for(a=0;a&lt;clipChangedCounter;a++){                  
      eventType = msg.slice(0,4);
      clipLen = parseInt(msg.slice(4,8),16);     
      clipName = hexToAscii(msg.slice(8,clipLen*2+8));
      if (eventType == '0001'){ clipsUpdate(folderName,clipName.toUpperCase(),'add','21','K2Primary');}
      if (eventType == '0002'){ clipsUpdate(folderName,clipName.toUpperCase(),'remove','21','K2Primary');} 
      msg = msg.slice(8+clipLen*2);       
      }
   if(msg.length&gt;0){IDsChangeEvent21(msg);}        
}
function IDsChangeEvent22(msg){
   ogscript.debug('22:recieved msg: ' + msg);  
   var volumeNamelength = parseInt(msg.slice(0,4),16);           msg = msg.slice(4);
   var volumeName=msg.slice(0,volumeNamelength * 2);             msg = msg.slice(volumeNamelength * 2);  
   var folderNameLen = parseInt(msg.slice(0,4),16);              msg = msg.slice(4);
   var folderName = hexToAscii(msg.slice(0,folderNameLen*2));    msg = msg.slice(folderNameLen * 2);  
   var clipChangedCounter = parseInt(msg.slice(0,2),16);         msg = msg.slice(2);
   var eventType,clipLen,clipName;
      
   for(a=0;a&lt;clipChangedCounter;a++){                  
      eventType = msg.slice(0,4);
      clipLen = parseInt(msg.slice(4,8),16);     
      clipName = hexToAscii(msg.slice(8,clipLen*2+8));
      if (eventType == '0001'){ clipsUpdate(folderName,clipName.toUpperCase(),'add','22','K2Secondary');}
      if (eventType == '0002'){ clipsUpdate(folderName,clipName.toUpperCase(),'remove','22','K2Secondary');} 
      msg = msg.slice(8+clipLen*2);       
      }
   if(msg.length&gt;0){IDsChangeEvent22(msg);}        
}

function clipsUpdate(bin,name,type,server,serverParam){
   ogscript.debug('bin: '+bin+ 'name: '+name+ 'type: '+type+'server: '+server+'serverParam: '+ serverParam);
   var list = ogscript.getObject('clips' + server);                            // get object with all cliplist from server (21 or 22).
   
   if(type == 'add'&amp;&amp;bin == params.getValue('workingBin', 0)){
      list.push({'name' : name, 'server' : params.getValue(serverParam, 0)});
      ogscript.putObject('clips'+server,list);
      matchListToKnownK2clip(name,params.getValue(serverParam, 0));
      ogscript.rename('bar',params.getValue(serverParam, 0) + ': ADDED '  + name)  
      clipListFinilize(); 
      }
    
   if(type == 'remove'&amp;&amp;bin == params.getValue('workingBin', 0)){
      
      for(i=0;i&lt;list.length;i++){
         
         if(list[i].name == name){
            
            list.splice(i,1);   // js splice: first parameter define index of element, the second one homa many elements to remove 
            ogscript.putObject('clips'+server,list);
            ogscript.rename('bar',params.getValue(serverParam, 0) + ': REMOVED '  + name)  
            clipListFinilize();
            ogscript.asyncExec(matchLists,300);            
         }     
      }
   }    
}</api>
      <api name="K2 NRCS">function loop(){
   
   var activeTable = ogscript.getObject('activeTable');   
   var selected = params.getValue('selected' + activeTable, 0);
   var loopIcon='&lt;style:fg#000000;i-u:images/loop.svg;&gt;';
   var status = params.getValue("ROTable" + activeTable +  "." + selected + ".loop",0);
   var cueStatus = params.getValue("ROTable" + activeTable +  "." + selected + ".cue",0);

   if (status==''){
      params.setValue("ROTable" + activeTable + "." + selected + ".loop",0, loopIcon); //turn on loop icon from table
      
      // if loop was pressed while clip is on play status (and loop icon is off)
      if(cueStatus==playIcon){
         var server,channelNum;
         var channel =   params.getValue("ROTable" + activeTable +  "." + selected + ".channel",0);
         if(channel==' A'||channel==' D'){channelNum=1}if(channel==' B'||channel==' E'){channelNum=2}if(channel==' C'||channel==' F'){channelNum=3}  
         if(channel==' A'||channel==' B'||channel==' C'){server = '1';}
         if(channel==' D'||channel==' E'||channel==' F'){server = '2';}   
         var player = ogscript.getObject('K2' + server + 'vtr' + channelNum); 
         player.writeString(loopON, false);         
         }
      
      }else{
         
      params.setValue("ROTable" + activeTable + "." + selected + ".loop",0, ''); //turn off loop icon from table
      
      // if loop was pressed while clip is on play status (and loop icon is on)
         if(cueStatus==playIcon){
            var server,channelNum;
            var channel =   params.getValue("ROTable" + activeTable +  "." + selected + ".channel",0);
            if(channel==' A'||channel==' D'){channelNum=1}if(channel==' B'||channel==' E'){channelNum=2}if(channel==' C'||channel==' F'){channelNum=3}  
            if(channel==' A'||channel==' B'||channel==' C'){server = '1';}
            if(channel==' D'||channel==' E'||channel==' F'){server = '2';}   
            var player = ogscript.getObject('K2' + server + 'vtr' + channelNum); 
            player.writeString(loopOFF, false);
            
      }
   }   
}


function vtrAssign(event){
      
   var state = event.getState();
   var activeTable = ogscript.getObject('activeTable');   
   var selected = params.getValue('selected' + activeTable, 0); 
   var video =  params.getValue("ROTable" + activeTable +  "." + selected + ".video",0);   
   var value;
   if(video!=''){
   if(state==1){value=' A'}if(state==2){value=' B'}if(state==3){value=' C'}if(state==4){value=' D'}if(state==5){value=' E'}if(state==6){value=' F'}
   var status = params.getValue("ROTable" + activeTable +  "." + selected + ".channel",0);
   
   if (status==value){
      params.setValue("ROTable" + activeTable + "." + selected + ".channel",0, '');   // story  
      }else{
      params.setValue("ROTable" + activeTable + "." + selected + ".channel",0, value);   // story     
         }
      }
   }


function cue(){
   var channelNum,server;
   var server1Name = params.getValue('K2Primary', 0);
   var server2Name = params.getValue('K2Secondary', 0);
   var activeTable = ogscript.getObject('activeTable');   
   var selected = params.getValue('selected' + activeTable, 0);
   var cueIcon='&lt;style:fg#000000;i-u:images/cue.svg;&gt;';
   var lineupCount = params.getElementCount('ROTable'+activeTable);      
   var loop =      params.getValue("ROTable" + activeTable +  "." + selected + ".loop",0);
   var video =     params.getValue("ROTable" + activeTable +  "." + selected + ".video",0);   
   var channel =   params.getValue("ROTable" + activeTable +  "." + selected + ".channel",0);
   var available = params.getValue("ROTable" + activeTable +  "." + selected + ".available",0);  
   if(channel==' A'||channel==' D'){channelNum=1}if(channel==' B'||channel==' E'){channelNum=2}if(channel==' C'||channel==' F'){channelNum=3}  
   if(channel==' A'||channel==' B'||channel==' C'){server = '1';}
   if(channel==' D'||channel==' E'||channel==' F'){server = '2';}   
   var player = ogscript.getObject('K2' + server + 'vtr' + channelNum); 
   
   //if the file exists on both servers
   if (video!=''&amp;&amp;channel!=''&amp;&amp;available==server1Name + ',' + server2Name){
      params.setValue("ROTable" + activeTable + "." + selected + ".cue",0, cueIcon);   // set cue icon
      player.writeString(ampMessageBuilder('V:/' + params.getValue('workingBin', 0) + '/' + video,'4a14'), false);
      params.setValue('player' + channel.slice(-1) + '.cueName', 0, video);   // set video name on player 
      if (loop == ''){ player.writeString(loopOFF, false);} else {player.writeString(loopON, false);}
      for (i=0;i&lt;lineupCount;i++){
         // This will find and cleanup prev cue on the same channel
         if (channel == params.getValue("ROTable" + activeTable +  "." + i + ".channel",0)&amp;&amp;i!=selected){ 
            params.setValue("ROTable" + activeTable + "." + i + ".cue",0, ''); 
            }         
         }
      }
   
   //if the file exists on only on primaryserver
   if (video!=''&amp;&amp;channel!=''&amp;&amp;available==server1Name){
      if(server == '1'){
         params.setValue("ROTable" + activeTable + "." + selected + ".cue",0, cueIcon);   // set cue icon
         player.writeString(ampMessageBuilder('V:/' + params.getValue('workingBin', 0) + '/' + video,'4a14'), false);
         params.setValue('player' + channel.slice(-1) + '.cueName', 0, video);   // set video name on player 
         if (loop == ''){ player.writeString(loopOFF, false);} else {player.writeString(loopON, false);}
         for (i=0;i&lt;lineupCount;i++){
            // This will find and cleanup prev cue on the same channel
            if (channel == params.getValue("ROTable" + activeTable +  "." + i + ".channel",0)&amp;&amp;i!=selected){params.setValue("ROTable" + activeTable + "." + i + ".cue",0, ''); }            
            }
         }
      }

   //if the file exists on only on secondary server
   if (video!=''&amp;&amp;channel!=''&amp;&amp;available==server2Name){
      if(server == '2'){
         params.setValue("ROTable" + activeTable + "." + selected + ".cue",0, cueIcon);   // set cue icon
         player.writeString(ampMessageBuilder('V:/' + params.getValue('workingBin', 0) + '/' + video,'4a14'), false);
         params.setValue('player' + channel.slice(-1) + '.cueName', 0, video);   // set video name on player    
         if (loop == ''){ player.writeString(loopOFF, false);} else {player.writeString(loopON, false);}
         for (i=0;i&lt;lineupCount;i++){
            // This will find and cleanup prev cue on the same channel
            if (channel == params.getValue("ROTable" + activeTable +  "." + i + ".channel",0)&amp;&amp;i!=selected){params.setValue("ROTable" + activeTable + "." + i + ".cue",0, ''); }            
            }
         }
      }   
   }


function play(){
  
   var channelNum,server;
   var activeTable = ogscript.getObject('activeTable');   
   var selected = params.getValue('selected' + activeTable, 0);
   
   var lineupCount = params.getElementCount('ROTable'+activeTable);      
   var channel =   params.getValue("ROTable" + activeTable +  "." + selected + ".channel",0);
   var available = params.getValue("ROTable" + activeTable +  "." + selected + ".available",0);
   var video =     params.getValue("ROTable" + activeTable +  "." + selected + ".video",0);   
   var cueStatus = params.getValue("ROTable" + activeTable +  "." + selected + ".cue",0);   
   if(channel==' A'||channel==' D'){channelNum=1}if(channel==' B'||channel==' E'){channelNum=2}if(channel==' C'||channel==' F'){channelNum=3}  
   if(channel==' A'||channel==' B'||channel==' C'){server = '1';}
   if(channel==' D'||channel==' E'||channel==' F'){server = '2';}
   var player = ogscript.getObject('K2' + server + 'vtr' + channelNum); 
   
   if (video!=''&amp;&amp;channel!=''&amp;&amp;available!=''&amp;&amp;cueStatus==cueIcon){
      ogscript.debug('play');
      params.setValue("ROTable" + activeTable + "." + selected + ".cue",0, playIcon);   // set play icon
      player.writeString(playON, false);  

      // This will find and cleanup prev cue on the same channel
      for (i=0;i&lt;lineupCount;i++){         
         if (channel == params.getValue("ROTable" + activeTable +  "." + i + ".channel",0)&amp;&amp;i!=selected){ 
            params.setValue("ROTable" + activeTable + "." + i + ".cue",0, ''); 
            }         
         }
      }
   params.setValue('selected'+ activeTable, 0, selected +1);

   }


function matchLists(){
   var K2Available,K2Video,inceptionVideo,inceptionAvailable;
   var K2ListCount = params.getElementCount('clipTable');             // constant list 
   var flag = false;

   //loop thru all 6 possible lineups   
   for (x = 1; x &lt; 7; x++) {                                                
      var lineupCount = params.getElementCount('ROTable'+x);           
      
      // loop thru all rows in lineup table  
      for(y=0;y&lt;lineupCount;y++){                                               
         inceptionVideo = params.getValue("ROTable" + x +"." + y + ".video", 0);
         
         //if there is no video on that row in table - skip
         if(inceptionVideo!==''){
            inceptionAvailable = params.getValue("ROTable" + x +"." + y + ".available", 0);
           
            //loop thru all rows in cliplist and match them to current lineup 'video' row  
            for(yy=0;yy&lt;K2ListCount;yy++){                                            
               K2Available = params.getValue("clipTable." + yy + ".available", 0); 
               K2Video = params.getValue("clipTable." + yy + ".clipname", 0);
               //This checks if the inceptionVideo matchs K2Video ==&gt; if not - it will set flag to true
               if(K2Video == inceptionVideo){
                  
                  flag = true;
                  //if available status is different
                  if(K2Available!==inceptionAvailable){ params.setValue("ROTable" + x + "." + y + ".available",0, K2Available); }
                                            
               }           
            }
     
         //This will clear table available, if there is no match, AND avilable wasn't empty before ('')
         if(flag==false&amp;&amp;inceptionAvailable!==''||flag==false&amp;&amp;inceptionAvailable!==redBackground){params.setValue("ROTable" + x + "." + y + ".available",0, redBackground);} else {flag = false;} 
         }
      }    
   }
   
  ogscript.debug('match list ends');
}


function matchListToKnownK2clip(K2clip,server){  
   var inceptionVideo,inceptionAvailable;
   var K2ListCount = params.getElementCount('clipTable');             // constant list    
   //loop thru all 6 possible lineups   
   for (x = 1; x &lt; 7; x++) {                                                
      var lineupCount = params.getElementCount('ROTable'+x);           
      
      // loop thru all rows in lineup table  
      for(y=0;y&lt;lineupCount;y++){                                               
         inceptionVideo = params.getValue("ROTable" + x +"." + y + ".video", 0);
         if(inceptionVideo!==''){
         
            inceptionAvailable = params.getValue("ROTable" + x +"." + y + ".available", 0);
            //This checks if the inceptionVideo matchs K2Video ==&gt; if not - it will set flag to true
            if(K2clip == inceptionVideo){
            
               //if available status is different
               if(''==inceptionAvailable){ params.setValue("ROTable" + x + "." + y + ".available",0, server); break;}
               else {params.setValue("ROTable" + x + "." + y + ".available",0, params.getValue('K2Primary', 0) + ',' + params.getValue('K2Secondary', 0)); break; }   
                                               
            }                 
         }    
      }
   }
}


ogscript.addRemoteTrigger ('loop','loop', loop);
ogscript.addRemoteTrigger ('vtr','vtr', vtrAssign);</api>
