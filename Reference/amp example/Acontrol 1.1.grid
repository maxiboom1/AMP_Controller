                  <button buttontype="push" height="40" left="20" name="" style="mask-u:images/play%20(1).svg;bg#tabbg;bdr#selectedmuted;bdr:round;" top="100" width="60">
                     <task tasktype="ogscript">var player = ogscript.getObject('K22vtr3'); 
player.writeString(playON, false);</task>
                  </button>
                  <button buttontype="push" height="40" left="80" name="" style="mask-u:images/stop.svg;bg#tabbg;bdr#selectedmuted;bdr:round;" top="100" width="60">
                     <task tasktype="ogscript">var player = ogscript.getObject('K22vtr3'); 
player.writeString(stop, false);</task>
                  </button>
                  <button buttontype="push" height="40" left="140" name="" style="mask-u:images/eject.svg;bg#tabbg;bdr#selectedmuted;bdr:round;" top="100" width="60">
                     <task tasktype="ogscript">var player = ogscript.getObject('K22vtr3'); 
player.writeString(eject, false);
params.setValue('playerF.cueName', 0, '');</task>
                  </button>
               </abs>
            </tr>
         </table>
         
         <label bottom="0" height="20" id="bar" name="" right="200" style="txt-align:west;fg#lightdivider;" width="1700"/>
         <label height="40" id="label.nrcs" left="1240" name="INCEPTION" style="txt-align:center;bdr#selectedmuted;bdr:round;font:bold;" top="0" width="80"/>
         <label height="40" id="label.k21" left="1320" name="" style="txt-align:center;bdr#selectedmuted;bdr:round;font:bold;" top="0" width="80"/>
         <label height="40" id="label.k22" left="1400" name="" style="txt-align:center;bdr#selectedmuted;bdr:round;font:bold;" top="0" width="80"/>
         <label height="40" left="1240" style="txt-align:west;bg#434A567C;" top="0" width="240"/>
         <abs anchor="west" bottom="20" id="settings-box" left="1240" name="CLOSE" style="bg#panelbg;bdr:etched;" tabhidden="true" tabstyle="bg#00000059;grid#0000003A;font:mono;" top="80" visible="false" width="320">
            <param expand="true" height="40" left="80" oid="hostNRCS" top="200" width="100"/>
            <label height="40" left="20" name="NRCS:" style="txt-align:west;" top="200" width="60"/>
            <param expand="true" height="180" left="6" oid="ledK2-1" scroll="vertical" top="760" width="454"/>
            <button buttontype="push" height="40" left="180" name="Connect" style="txt-align:west;bg-fill:none;bg#tableheader;" top="200" width="100">
               <task tasktype="ogscript">var ip = params.getValue('hostNRCS', 0);
var client = ogscript.getListenerById ('client10541');
var server = ogscript.getListenerById ('server10541');

if(client.isStarted() ==true&amp;&amp;server.isStarted()&amp;&amp;true){
   client.stop();
   server.stop();
   } else {
      
   client.connectTo(ip, 10541);
   server.start();            
      }</task>
            </button>
            <param expand="true" height="40" left="240" oid="led2" top="200" width="40">
               <task tasktype="ogscript">labelUpdate('led2');</task>
            </param>
            <param expand="true" height="40" left="240" oid="led" top="200" width="20">
               <task tasktype="ogscript">labelUpdate('led');</task>
            </param>
            <button buttontype="push" height="40" left="180" name="Connect" style="txt-align:west;bg#tableheader;" top="240" width="100">
               <task tasktype="ogscript">var listenerA = ogscript.getListenerById('K21.vtr1'); 
var listenerB = ogscript.getListenerById('K21.vtr2'); 
var listenerC = ogscript.getListenerById('K21.vtr3'); 
var ip = params.getValue('hostK21', 0);

if(listenerA.isStarted()){
   listenerA.stop();
   listenerB.stop();
   listenerC.stop();

   } else {
   listenerA.connectTo(ip, 3811);
   listenerB.connectTo(ip, 3811);
   listenerC.connectTo(ip, 3811);
      }</task>
            </button>
            <param expand="true" height="40" left="80" oid="hostK21" top="240" width="100"/>
            <label height="40" left="20" name="K2-1:" style="txt-align:west;" top="240" width="60"/>
            <label height="40" left="20" name="K2-2:" style="txt-align:west;" top="280" width="60"/>
            <param expand="true" height="40" left="80" oid="hostK22" top="280" width="100"/>
            <button buttontype="push" height="40" left="180" name="Connect" style="txt-align:west;bg#tableheader;" top="280" width="100">
               <task tasktype="ogscript">var listenerD = ogscript.getListenerById('K22.vtr1'); 
var listenerE = ogscript.getListenerById('K22.vtr2'); 
var listenerF = ogscript.getListenerById('K22.vtr3'); 

var ip = params.getValue('hostK22', 0);


if(listenerD.isStarted()){
   listenerD.stop();
   listenerE.stop();
   listenerF.stop();
   } else {
   listenerD.connectTo(ip, 3811);
   listenerE.connectTo(ip, 3811);
   listenerF.connectTo(ip, 3811);
      }</task>
            </button>
            <param expand="true" height="40" left="1620" oid="ledK2-2" top="160" width="40"/>
            <param expand="true" height="40" left="240" oid="ledK22" top="280" width="40">
               <task tasktype="ogscript">labelUpdate('k22');
ogscript.asyncExec(matchLists,3000);</task>
            </param>
            <button buttontype="push" gpi="play" height="40" left="0" name="play" top="680" visible="false" width="60">
               <task tasktype="ogscript">play();</task>
            </button>
            <button buttontype="push" gpi="cue" height="40" left="60" name="cue" top="680" visible="false" width="60">
               <task tasktype="ogscript">cue();</task>
            </button>
            <button buttontype="push" height="40" left="120" name="test table" top="680" visible="false" width="80">
               <task tasktype="ogscript">var test = [
{"available": "TLV1" ,"clipname":"blablabla" },
{"available": "TLV1" ,"clipname":"blablabla2" },
{"available": "TLV1" ,"clipname":"blablabla3" },
{"available": "TLV1" ,"clipname":"blablabla4" },
{"available": "TLV1" ,"clipname":"blablabla5" },
{"available": "TLV1" ,"clipname":"blablabla6" },
{"available": "TLV1" ,"clipname":"blablabla7" },
{"available": "TLV1" ,"clipname":"blablabla8" },
{"available": "TLV1" ,"clipname":"blablabla9" },
{"available": "TLV1" ,"clipname":"blablabla10" },
{"available": "TLV1" ,"clipname":"blablabla11" }

];
params.setAllValues('clipTable', test);</task>
            </button>
            <param expand="true" height="20" left="60" oid="binList" style="bdr:line;" top="760" visible="false" width="140"/>
            <help height="40" left="40" name="About this software release" style="bg#1D3A37;font:default;fg#panelfg;look:round;" title="Acontrol 1.1" top="780" width="240">&lt;html&gt;&lt;left&gt; 1.06 release updates:
&lt;br/&gt;&lt;br/&gt;Fixed: Play moves selection to next item.
&lt;br/&gt;Fixed :Cue sends full-path clipname to K2.
&lt;br/&gt;Fixed: Disabled vtr-assign to non-video items.
&lt;br/&gt;Fixed: Disabled play on non-cued items.
&lt;br/&gt;Fixed: Cue now updates players.
&lt;br/&gt;Fixed: N/A videos are red-labeled.
&lt;br/&gt;Fixed: Loop can be changed while playing.
&lt;br/&gt;&lt;br/&gt;1.1 release updates:
&lt;br/&gt;&lt;br/&gt;Fixed: Added roMetadataReplace event (ro rename, date changes itc).
&lt;br/&gt;Debug: Mos protocol log (daily splitted) .
&lt;br/&gt;&lt;br/&gt;Created by Alex, 2020-2021&lt;/left&gt;&lt;/html&gt;</help>
            <label height="60" left="0" name="Acontrol 1.1" right="0" style="txt-align:center;size:28;font:mono;fg#selectbg;" top="40"/>
