function binListFinilize21(serverDisconnect){   
   var binList = ogscript.getObject('binList21');               // get array object with first bin name from list1Folder func.
   var binList22 = ogscript.getObject('binList22');
   binList = binList.concat(binList22); 
   var choiceConstraint = params.createIntChoiceConstraint(binList.filter(onlyUnique));
   params.replaceConstraint("binList", choiceConstraint);
   if(serverDisconnect!==true){setBin21(params.getValue('workingBin', 0));}
              
   }  
function binListFinilize22(serverDisconnect){   
   var binList = ogscript.getObject('binList22');               // get array object with first bin name from list1Folder func.
   var binList21 = ogscript.getObject('binList21');
   binList = binList.concat(binList21); 
   var choiceConstraint = params.createIntChoiceConstraint(binList.filter(onlyUnique));
   params.replaceConstraint("binList", choiceConstraint);
   if(serverDisconnect!==true){setBin22(params.getValue('workingBin', 0)); ogscript.debug('22:fired setBin ' + params.getValue('workingBin', 0));}                                         // this will copy the list also to binListCopy parameter
              
   }     

function nextIdRequest21(){  
