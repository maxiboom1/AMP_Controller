   var server = ogscript.getObject('K22vtr1');
   server.writeString(listFirstFolderALIAS, false);      
   } 
        
function list1Folder21(msg){   
   var binList = dataConvertor(msg,msg.length,'');                // Pass msg to dataConvertor() and get first folder name string
   ogscript.putObject('binList21',binList);                     // Overwrite 'binList' array object with the first folder name. 
   nextFolderRequest21();  
      }
