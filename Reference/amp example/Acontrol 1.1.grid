   <timertask tasktype="ogscript">function delayedRequest(){
   if(server22!==null){   
   server22.writeString(IDsChangeListReqALIAS, false);  
   }
}



var server21 = ogscript.getObject('K21vtr1');
var server22 = ogscript.getObject('K22vtr1');   
   
