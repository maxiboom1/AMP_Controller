      <listener autostart="false" blockingpause="true" connecthost="10.168.1.89" connectport="3811" delimiter="1" delimitertype="fixedlen" height="40" id="K21.vtr1" left="940" name="A" top="100" width="80">
         <task tasktype="ogscript">if (event.isConnectEvent())
{ 
ogscript.putObject('K21vtr1', this);
this.writeString(vtr1Connection, false);
ogscript.putObject('firstConnection1', true); 
params.setValue('ledK21', 0, '&lt;#green&gt;');
}

if (event.isMessageEvent())
{
 var messageReader = ogscript.createMessageParser(this.getInputStream());
 var response = event.getBytesAsString();
 var bytesArr = messageReader.readBytes(3);
 var i; var ampLen = "";
 
 for (i = 0; i &lt; 3; i++) {
     response += String.fromCharCode(bytesArr[i]);
   }

   //ogscript.debug('FROM LISTENERK21: ' + response);
  
  if(response == ackALIAS||response == nakALIAS || response == binListCompleteALIAS || response == noMoreIdALIAS||response == error ){
      
      messageRouterK21(response);
     
      if(ogscript.getObject('firstConnection1') == true){         // This condition runs if the ack was 
         firstFolderRequest21();                                   // recieved for the first time connection, 
         ogscript.putObject('firstConnection1', false); }         // if so he fires 'listFirstFolder'
      
      } else {
         
     var bytesArr = messageReader.readBytes(4);                  //  00090007646 for example
     for (i = 0; i &lt; 4; i++) {
     
        ampLen += String.fromCharCode(bytesArr[i]);
           } 
        response += ampLen;      


     var finalMsg = messageReader.readBytes(parseInt(ampLen,16)*2);
     for (i = 0; i &lt; parseInt(ampLen,16)*2; i++) {
     
        response += String.fromCharCode(finalMsg[i]);
           }    
     messageRouterK21(response);
         }                  
}

else if (event.isDisconnectEvent())
{
   var x = ogscript.getObject('K21vtr1');
   if (x == this)
   {
      params.setValue('ledK21', 0, '&lt;#red&gt;');
      ogscript.putObject('binList21',emptyArr); 
      binListFinilize22(true); //true flag means serverDisconnect 
      ogscript.putObject('clips21',emptyArr);
      clipListFinilize(); 
      ogscript.putObject('K21vtr1',null);     
   }
}</task>
      </listener>
